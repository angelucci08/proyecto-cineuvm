<!DOCTYPE html>
<html>
<head>
    <title>Salas del Cine</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #2c3e50; color: white; }
        tr:nth-child(even) { background-color: #f2f2f2; }
        .btn-volver { display: inline-block; margin-bottom: 20px; padding: 8px 15px; background: #7f8c8d; color: white; text-decoration: none; border-radius: 4px; }
    </style>
</head>
<body>
    <a href="/" class="btn-volver">⬅ Volver al Menú</a>
    <h2>🏢 Infraestructura: Salas Disponibles</h2>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre de la Sala</th>
                <th>Capacidad Máxima</th>
            </tr>
        </thead>
        <tbody>
            <% salas.forEach(function(sala) { %>
                <tr>
                    <td><%= sala.id %></td>
                    <td><%= sala.nombre %></td>
                    <td><%= sala.capacidad %> asientos</td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</body>
</html>