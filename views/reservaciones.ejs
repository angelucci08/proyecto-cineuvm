<!DOCTYPE html>
<html>
<head>
    <title>Reservaciones</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #8e44ad; color: white; }
        tr:nth-child(even) { background-color: #f2f2f2; }
        .btn-volver { display: inline-block; margin-bottom: 20px; padding: 8px 15px; background: #7f8c8d; color: white; text-decoration: none; border-radius: 4px; }
    </style>
</head>
<body>
    <a href="/" class="btn-volver">⬅ Volver al Menú</a>
    <h2>🎫 Reservas de Asientos Activas</h2>
    <table>
        <thead>
            <tr>
                <th>ID Reserva</th>
                <th>ID Función</th>
                <th>Cliente Titular</th>
                <th>Boletos Reservados</th>
                <th>Fecha de Operación</th>
            </tr>
        </thead>
        <tbody>
            <% reservaciones.forEach(function(r) { %>
                <tr>
                    <td><%= r.id %></td>
                    <td>Función #<%= r.funcionId %></td>
                    <td><strong><%= r.cliente %></strong></td>
                    <td><%= r.cantidadAsientos %></td>
                    <td><%= r.fechaReservacion %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</body>
</html>