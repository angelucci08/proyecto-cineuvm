<!DOCTYPE html>
<html>
<head>
    <title>Cartelera de Películas</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #34495e; color: white; }
        tr:nth-child(even) { background-color: #f2f2f2; }
        .btn-volver { display: inline-block; margin-bottom: 20px; padding: 8px 15px; background: #7f8c8d; color: white; text-decoration: none; border-radius: 4px; }
    </style>
</head>
<body>
    <a href="/" class="btn-volver">⬅ Volver al Menú</a>
    <h2>🎥 Listado de Películas en Cartelera</h2>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Título</th>
                <th>Duración</th>
                <th>Género</th>
                <th>Fecha de Estreno</th>
            </tr>
        </thead>
        <tbody>
            <% peliculas.forEach(function(pelicula) { %>
                <tr>
                    <td><%= pelicula.id %></td>
                    <td><strong><%= pelicula.titulo %></strong></td>
                    <td><%= pelicula.duracion %> min</td>
                    <td><%= pelicula.genero %></td>
                    <td><%= pelicula.fechaEstreno %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</body>
</html>